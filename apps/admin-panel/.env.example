# ──────────────────────────────────────────────────────────────
# Handy Go — Admin Panel Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# All variables are optional — defaults point to Appwrite Cloud (Frankfurt).
# ──────────────────────────────────────────────────────────────

# Appwrite endpoint (default: Frankfurt Cloud)
VITE_APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1

# Appwrite project ID
VITE_APPWRITE_PROJECT_ID=handygo

# Appwrite database ID
VITE_APPWRITE_DATABASE_ID=handy_go_db
